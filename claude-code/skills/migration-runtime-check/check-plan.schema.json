{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "migration-runtime-check check-plan",
  "type": "object",
  "required": ["app", "baseline", "candidate", "auth", "contexts", "scenarios"],
  "additionalProperties": false,
  "properties": {
    "app": {
      "type": "string",
      "description": "Build unit name under apps/<app>/."
    },
    "intent": {
      "type": "string",
      "description": "Free-form why-this-plan-exists note."
    },
    "baseline": {
      "type": "object",
      "required": ["branch", "baseUrl"],
      "additionalProperties": false,
      "properties": {
        "branch": { "type": "string" },
        "baseUrl": { "type": "string" }
      }
    },
    "candidate": {
      "type": "object",
      "required": ["branch", "baseUrl"],
      "additionalProperties": false,
      "properties": {
        "branch": { "type": "string" },
        "baseUrl": { "type": "string" }
      }
    },
    "auth": {
      "type": "object",
      "required": ["storageState"],
      "additionalProperties": false,
      "properties": {
        "storageState": {
          "type": ["string", "null"],
          "description": "Path to Playwright storageState JSON, or null for unauthenticated runs."
        },
        "actor": { "type": "string" },
        "role": { "type": "string" }
      }
    },
    "knownUnstable": {
      "type": "array",
      "description": "Substring patterns treated as noise when matched against classes / texts / non-error console signals.",
      "items": { "type": "string" }
    },
    "contexts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "vars"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "auth": {
            "type": ["string", "null"],
            "description": "Optional per-context storageState path; falls back to top-level auth.storageState."
          },
          "vars": {
            "type": "object",
            "description": "Route variable substitutions, e.g. {\"group_id\": \"2\"}.",
            "additionalProperties": { "type": "string" }
          },
          "labels": {
            "type": "array",
            "description": "Optional short human-readable tags shown in report. Compare tool does not interpret values.",
            "items": { "type": "string" }
          },
          "metadata": {
            "type": "object",
            "description": "Free-form metadata preserved in capture/report. Any JSON value allowed for any key (Korean keys permitted). Compare tool does not interpret values.",
            "additionalProperties": true
          }
        }
      }
    },
    "scenarios": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "routeTemplate", "context", "path", "expectedFinalPath"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "description": "Stable scenarioId used as pageId on both sides. Must be unique within the plan."
          },
          "reason": { "type": "string" },
          "routeTemplate": {
            "type": "string",
            "description": "Original Angular route with :param placeholders."
          },
          "context": {
            "type": "string",
            "description": "id of a contexts[] entry."
          },
          "path": {
            "type": "string",
            "description": "Concrete URL path to navigate to (vars already substituted)."
          },
          "expectedFinalPath": {
            "type": "string",
            "description": "Path the page must end up on for the capture to be considered valid for deep diff."
          },
          "compare": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["page-capture", "actions", "console-runtime"]
            },
            "description": "Which signal groups to evaluate. Empty array implies all three."
          },
          "actions": {
            "type": "array",
            "description": "Approved safe UI actions to execute after the initial capture. v1 supports click only.",
            "items": {
              "type": "object",
              "required": ["id", "kind", "steps"],
              "additionalProperties": false,
              "properties": {
                "id": { "type": "string" },
                "kind": {
                  "type": "string",
                  "enum": ["safe-ui-action"]
                },
                "description": { "type": "string" },
                "snapshotAfterEachStep": {
                  "type": "boolean",
                  "description": "Capture step snapshot after each step. Default true."
                },
                "steps": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "object",
                    "required": ["type", "selector"],
                    "additionalProperties": false,
                    "properties": {
                      "type": {
                        "type": "string",
                        "enum": ["click"]
                      },
                      "selector": {
                        "type": "string",
                        "description": "Prefer [data-testid=...]; aria-label / role+name acceptable. Generated class selectors are not allowed."
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
